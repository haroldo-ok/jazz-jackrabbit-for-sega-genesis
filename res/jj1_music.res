// Jazz Jackrabbit soundtrack, converted to Genesis VGM by
// github.com/haroldo-ok/convert-s3m-vgm-jazzjackrabbit-md and compiled here by
// SGDK's xgmtool into the XGM Z80 driver format.  One track per world plus the
// title theme; regenerate from your own converted VGMs if you replace them.
XGM jj1_music_menu        "music/menu.vgm"
XGM jj1_music_diamondus   "music/diamondus.vgm"
XGM jj1_music_tubelectric "music/tubelectric.vgm"
XGM jj1_music_medivo      "music/medivo.vgm"
